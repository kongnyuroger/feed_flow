{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.0"
    }
  },
  "routes": [
    {
      "src": "^/test-simple\\.php$",
      "dest": "/api/test-simple.php"
    },
    {
      "src": "^/(.*)\\.php$",
      "dest": "/api/$1.php"
    },
    {
      "src": "^/style\\.css$",
      "dest": "/public/style.css"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.php"
    }
  ],
  "overrides": {
    "api/*.php": {
      "headers": {
        "Content-Type": "text/html; charset=utf-8"
      }
    }
  }
}
