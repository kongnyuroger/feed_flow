{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.0"
    }
  },
  "routes": [
    {
      "src": "^/(.*)\\.php$",
      "dest": "/api/$1.php"
    },
    {
      "src": "^/style\\.css$",
      "dest": "/public/style.css"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.php"
    }
  ]
}
